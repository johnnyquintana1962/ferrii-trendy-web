rules_version = '2';

// Reglas de seguridad de Firestore para Ferrii Trendy.
// - Lectura PÚBLICA: el catálogo debe verse sin login.
// - Escritura solo para ADMIN autenticado (Firebase Auth): evita que cualquiera
//   pueda modificar o borrar productos/categorías desde afuera.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
