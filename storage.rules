rules_version = '2';

// Reglas de seguridad de Firebase Storage para Ferrii Trendy.
// - Lectura PÚBLICA: las fotos/videos deben cargar para cualquier visitante.
// - Escritura solo para ADMIN autenticado (Firebase Auth).
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
